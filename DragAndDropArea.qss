#dragAndDropContainer {
    border: 2px solid #0066cc;
    border-radius: 8px;
    padding: 40px;
    background-color: #333333;
}

#dragDropArea {
    color: #ffffff;
    font-size: 14px;
}

#dragDropButton {
    background-color: #0066cc;
    color: #ffffff;
    border-radius: 4px;
    padding: 8px 16px;
    border: none;
}

#dragDropButton:hover {
    background-color: #0052a3;
}